{
  "name": "depot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Chariot Depot — UI asset center for the Harness generation chain",
  "workspaces": [
    "packages/contracts",
    "packages/tokens",
    "packages/web-radix",
    "packages/universal-nativewind",
    "packages/blocks",
    "packages/manifests"
  ],
  "scripts": {
    "build": "tsc -b",
    "build:registry": "tsx scripts/buildRegistry.ts",
    "test": "vitest run",
    "lint": "eslint --no-error-on-unmatched-pattern packages tests scripts eslint.config.mjs",
    "lint:arch": "depcruise --config .dependency-cruiser.cjs \"packages/**/src/**/*.ts\"",
    "typecheck": "tsc -b --verbose",
    "verify:profiles": "tsx scripts/verifyProfiles.ts",
    "export:profiles": "tsx scripts/exportProfiles.ts",
    "verify:tokens": "tsx scripts/syncTokens.ts --check",
    "doctor": "npm run typecheck && npm run lint && npm run lint:arch && npm test"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.9.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dependency-cruiser": "^16.10.4",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "vitest": "^4.1.2",
    "zod": "^3.23.8"
  }
}
