{
  "name": "depot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Chariot Depot - UI asset center for the Harness generation chain",
  "workspaces": [
    "packages/contracts",
    "packages/tokens",
    "packages/web-radix",
    "packages/universal-nativewind",
    "packages/blocks",
    "packages/manifests"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:registry": "tsx scripts/buildRegistry.ts",
    "dev": "tsx src/cli.ts",
    "test": "vitest",
    "test:contracts": "vitest --config packages/contracts/vitest.config.ts",
    "test:manifests": "vitest --config packages/manifests/vitest.config.ts",
    "lint": "eslint packages tests scripts eslint.config.mjs",
    "lint:arch": "depcruise --config .dependency-cruiser.cjs \"packages/**/src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "verify:profiles": "tsx scripts/verifyProfiles.ts",
    "verify:tokens": "tsx scripts/syncTokens.ts --check",
    "doctor": "npm run typecheck && npm run lint && npm run lint:arch && npm test -- --run"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.9.1",
    "dependency-cruiser": "^16.10.4",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "vitest": "^4.1.2",
    "zod": "^3.23.8"
  }
}
